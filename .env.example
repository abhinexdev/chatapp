# Copy this file to .env and fill in your values
# cp .env.example .env

# Django core
SECRET_KEY=replace-me-with-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# PostgreSQL (leave blank to use SQLite in dev)
DB_NAME=chatapp
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis (required for production WebSocket scaling)
REDIS_URL=redis://127.0.0.1:6379
